            ws.cell(row=row_no, column=5).value = "INR"
            ws.cell(row=row_no, column=6).value = period_val
            ws.cell(row=row_no, column=7).value = period_val
            ws.cell(row=row_no, column=8).value = "MP payout"
            ws.cell(row=row_no, column=9).value = "91000467"
            ws.cell(row=row_no, column=10).value = ""
            ws.cell(row=row_no, column=11).value = -merchant_pay
            ws.cell(row=row_no, column=12).value = ""
            ws.cell(row=row_no, column=13).value = merchant_pay
            ws.cell(row=row_no, column=14).value = ""
            ws.cell(row=row_no, column=15).value = "FINANCE"
            ws.cell(row=row_no, column=16).value = f"MP payout Escrow {period_val}"

            row_no += 1

        wb.save(GOOGLE_UPLOADER_FILE)
