    except Exception as e:
        print(f"â Error in Google Payment Uploader: {e}")


# ---------------- JV UPLOADER (UPDATED WITH B REQUIREMENT) ---------------- #
def generate_jv_uploader():
    try:
        print("Generating JV Uploader...")

        df_output = pd.read_excel(JV_SOURCE_FILE)
        mm_df = pd.read_csv(MM_FILE, encoding='latin1')

        df_output["GMV"] = pd.to_numeric(df_output["GMV"], errors='coerce').fillna(0)

        df_pivot = df_output.groupby(["MID_WID", "Status"])["GMV"].sum().reset_index()

        df_payout = df_pivot[df_pivot["Status"] == "Payout"].rename(columns={"GMV": "Payout"})
        df_return = df_pivot[df_pivot["Status"] == "Return"].rename(columns={"GMV": "Return"})

        df_merged = pd.merge(df_payout[["MID_WID", "Payout"]],
                             df_return[["MID_WID", "Return"]],
                             on="MID_WID",
                             how="outer")

        df_merged["Payout"] = df_merged["Payout"].fillna(0)
        df_merged["Return"] = df_merged["Return"].fillna(0)
        df_merged["Total"] = df_merged["Payout"] + df_merged["Return"]

        mm_df["MID_WID"] = mm_df["MID_WID"].astype(str)
        df_merged["MID_WID"] = df_merged["MID_WID"].astype(str)

        df_merged = pd.merge(df_merged,
                             mm_df[["MID_WID", "SAP_New_Code"]],
                             on="MID_WID",
                             how="left")

        df_merged.rename(columns={"SAP_New_Code": "SAP"}, inplace=True)

        # ------------ B REQUIREMENT BELOW ------------ #

        # Load JV FORMAT file
        wb = load_workbook(JV_FORMAT_FILE)

        # Rename template sheet "Sheet1" â "SAP_Uploader"
        ws_template = wb["Sheet1"]
        ws_template.title = "SAP_Uploader"

        # Create NEW sheet "Gross"
        if "Gross" in wb.sheetnames:
            del wb["Gross"]
        ws_new = wb.create_sheet("Gross")

        # Insert required headers
        headers = ["MID_WID", "Payout", "Return", "Total", "SAP"]
        for col_idx, col_name in enumerate(headers, 1):
            ws_new.cell(row=1, column=col_idx).value = col_name

        # Write data under headers
        for row_idx, row in df_merged.iterrows():
            ws_new.cell(row=row_idx + 2, column=1).value = row["MID_WID"]
            ws_new.cell(row=row_idx + 2, column=2).value = row["Payout"]
            ws_new.cell(row=row_idx + 2, column=3).value = row["Return"]
            ws_new.cell(row=row_idx + 2, column=4).value = row["Total"]
            ws_new.cell(row=row_idx + 2, column=5).value = row["SAP"]

        wb.save(JV_OUTPUT_FILE)
        print(f"â JV Uploader created with two sheets: SAP_Uploader + Gross â {JV_OUTPUT_FILE}")

    except Exception as e:
        print(f"â JV Uploader Error: {e}")


