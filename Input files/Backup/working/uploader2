def send_gmail(attachment_path):
    try:
        current_date = datetime.now().strftime('%d-%m-%Y')
        subject = f"SAP Payment uploader dated {current_date}"
        body = f"Please find the attached SAP Payment Uploader file for {current_date}."

        msg = MIMEMultipart()
        msg['From'] = SENDER_EMAIL
        # Convert list to comma-separated string for the email header
        msg['To'] = ", ".join(RECEIVER_EMAIL)
        msg['Subject'] = subject
        msg.attach(MIMEText(body, 'plain'))

        # Attach file safely
        if os.path.exists(attachment_path):
            filename = os.path.basename(attachment_path)
            with open(attachment_path, "rb") as attachment:
                part = MIMEBase('application', 'octet-stream')
                part.set_payload(attachment.read())
                encoders.encode_base64(part)
                part.add_header('Content-Disposition', f"attachment; filename= {filename}")
                msg.attach(part)

            # Server connection
            server = smtplib.SMTP('smtp.gmail.com', 587)
            server.starttls()
            server.login(SENDER_EMAIL, SENDER_PASSWORD)
            # Use the list directly for the envelope recipients
            server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, msg.as_string())
            server.quit()
            print(f"📧 Email sent successfully to: {msg['To']}")
        else:
            print("❌ Attachment file not found.")
            
    except Exception as e:
        print(f"❌ Failed to send email: {e}")

def generate_sap_upload():
    try:
        print("Starting SAP Uploader Generation...")

        if not os.path.exists(SAP_TEMPLATE_PATH) or not os.path.exists(PERIOD_FILE_PATH):
            print("❌ Error: Missing template or Period.xlsx file.")
            return

        # Read Period
        period_df = pd.read_excel(PERIOD_FILE_PATH, header=None)
        period_val = str(period_df.iloc[0, 0]).strip()

        # Read Date
        raw_df = pd.read_csv(RAW_DATA_FILE, usecols=['settled_at'], encoding='latin1', nrows=1)
        raw_date = pd.to_datetime(raw_df['settled_at'].iloc[0]).strftime('%d.%m.%Y')

        # Read Payment Data
        pay_df = pd.read_excel(INPUT_PAYMENT_SHEET)
        sap_entries = []

        # Logic: Strictly excludes zero and NaN values
        # GL 91000467 -> Nodal | GL 91000463 -> Cod
        mapping = [('91000467', 'net pg_payable', 'Nodal'), 
                   ('91000463', 'net_cod_payable', 'Cod')]
        
        for gl_code, col, txt_prefix in mapping:
            for _, row in pay_df.iterrows():
                val = pd.to_numeric(row[col], errors='coerce')
                if pd.notnull(val) and val > 0:
                    sap_entries.append({
                        'Customer': row['SAP'],
                        'Document_Date': raw_date,
                        'Posting_Date': raw_date,
                        'Company_Code': 'MKPL',
                        'Currency_Rate': 'INR',
                        'Reference': period_val,
                        'Doc_Header_Text': period_val,
                        'Assignment': 'MP payout',
                        'GL': gl_code,
                        'GST': '',
                        'Amount_GL': -abs(round(float(val), 2)),
                        'Amount_GST': '',
                        'Amount_Customer': abs(round(float(val), 2)),
                        'Profit_Center': '',
                        'Cost_Center': 'FINANCE',
                        'Text': f"MP payout {txt_prefix} {period_val}"
                    })

        if not sap_entries:
            print("⚠️ No data found with payables > 0. SAP file not generated.")
            return

        # Write to Excel Template
        wb = load_workbook(SAP_TEMPLATE_PATH)
        ws = wb.active 
        for i, entry in enumerate(sap_entries):
            r = 2 + i
            values = [
                entry['Customer'], entry['Document_Date'], entry['Posting_Date'], 
                entry['Company_Code'], entry['Currency_Rate'], entry['Reference'], 
                entry['Doc_Header_Text'], entry['Assignment'], entry['GL'], 
                entry['GST'], entry['Amount_GL'], entry['Amount_GST'], 
                entry['Amount_Customer'], entry['Profit_Center'], 
                entry['Cost_Center'], entry['Text']
            ]
            for c, val in enumerate(values, 1):
                ws.cell(row=r, column=c).value = val

        wb.save(SAP_OUTPUT_FILE)
        print(f"✅ SUCCESS: File generated as {SAP_OUTPUT_FILE}")
        send_gmail(SAP_OUTPUT_FILE)

    except Exception as e:
        print(f"❌ Critical Error: {e}")

if __name__ == "__main__":
    generate_sap_upload()