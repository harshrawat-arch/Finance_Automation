def send_gmail(attachments):
    try:
        current_date = datetime.now().strftime('%d-%m-%Y')
        subject = f"SAP + Google Payment uploader dated {current_date}"
        body = f"Please find the attached SAP & Google Payment Uploader files for {current_date}."
        
        msg = MIMEMultipart()
        msg['From'] = SENDER_EMAIL
        msg['To'] = ", ".join(RECEIVER_EMAIL)
        msg['Subject'] = subject
        msg.attach(MIMEText(body, 'plain'))
        
        for path in attachments:
            if os.path.exists(path):
                filename = os.path.basename(path)
                with open(path, "rb") as f:
                    part = MIMEBase('application', 'octet-stream')
                    part.set_payload(f.read())
                    encoders.encode_base64(part)
                    part.add_header('Content-Disposition', f"attachment; filename={filename}")
                    msg.attach(part)
            else:
                print(f"⚠️ Warning: Attachment not found: {path}")
                    
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        server.login(SENDER_EMAIL, SENDER_PASSWORD)
        server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, msg.as_string())
        server.quit()
        print("📧 Email sent successfully (SAP & Google files only).")
    except Exception as e: 
        print(f"❌ Email error: {e}")

def generate_sap_upload():
    try:
        print("Starting Uploader Generation...")
        # 1. Get Period and Date
        period_df = pd.read_excel(PERIOD_FILE_PATH, header=None)
        period_val = str(period_df.iloc[0, 0]).strip()
        
        raw_df = pd.read_csv(RAW_DATA_FILE, usecols=['settled_at'], encoding='latin1', nrows=1)
        raw_date = pd.to_datetime(raw_df['settled_at'].iloc[0]).strftime('%d.%m.%Y')
        
        pay_df = pd.read_excel(INPUT_PAYMENT_SHEET)

        # 2. Generate SAP Payment Uploader
        sap_entries = []
        mapping = [('91000467', 'net pg_payable', 'Escrow'), ('91000463', 'net_cod_payable', 'Cod')]
        
        for gl, col, txt in mapping:
            for _, row in pay_df.iterrows():
                val = pd.to_numeric(row[col], errors='coerce')
                if pd.notnull(val) and val > 0:
                    sap_entries.append({
                        'Customer': row['SAP'], 'Date': raw_date, 'PostDate': raw_date, 
                        'Co': 'MKPL', 'Curr': 'INR', 'Ref': period_val, 'Head': period_val, 
                        'Assign': 'MP payout', 'GL': gl, 'GST': '', 
                        'AmGL': -abs(round(float(val), 2)), 'AmGST': '', 
                        'AmCust': abs(round(float(val), 2)), 'PC': '', 
                        'CC': 'FINANCE', 'Txt': f"MP payout {txt} {period_val}"
                    })

        wb = load_workbook(SAP_TEMPLATE_PATH)
        ws = wb.active
        # Clear template data first if necessary, then write
        for i, entry in enumerate(sap_entries):
            for c, val in enumerate(entry.values(), 1):
                ws.cell(row=2+i, column=c).value = val
        wb.save(SAP_OUTPUT_FILE)
        print(f"✅ SAP File saved: {SAP_OUTPUT_FILE}")

        # 3. Generate Google Uploader
        generate_google_payment_uploader(pay_df, period_val, raw_date)

        # 4. Send Email (Excluding JV)
        send_gmail([SAP_OUTPUT_FILE, GOOGLE_UPLOADER_FILE])

    except Exception as e: 
        print(f"❌ Critical Error: {e}")

def generate_google_payment_uploader(pay_df, period_val, raw_date):
    try:
        google_sap_list = ["8302253", "8302697"]
        df_google = pay_df[pay_df["SAP"].astype(str).isin(google_sap_list)].copy()
        
        wb = load_workbook(SAP_TEMPLATE_PATH)
        ws = wb.active
        
        for idx, row in enumerate(df_google.iterrows(), 2):
            r = row[1]
            val = round(float(pd.to_numeric(r["GMV"], errors='coerce') or 0), 2)
            data = [
                r["SAP"], raw_date, raw_date, "MKPL", "INR", period_val, period_val, 
                "MP payout", "91000467", "", -val, "", val, "", "FINANCE", 
                f"MP payout Escrow {period_val}"
            ]
            for c, v in enumerate(data, 1):
                ws.cell(row=idx, column=c).value = v
                
        wb.save(GOOGLE_UPLOADER_FILE)
        print(f"✅ Google Payment Uploader saved: {GOOGLE_UPLOADER_FILE}")
    except Exception as e: 
        print(f"❌ Google Uploader Error: {e}")

if __name__ == "__main__":
    generate_sap_upload()