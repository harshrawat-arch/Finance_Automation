# ---------------- EMAIL SENDER ---------------- #
def send_gmail(attachments):
    try:
        current_date = datetime.now().strftime('%d-%m-%Y')
        subject = f"SAP + Google + JV Payment uploader dated {current_date}"
        body = f"Please find the attached SAP, Google & JV Payment Uploader files for {current_date}."
        
        msg = MIMEMultipart()
        msg['From'] = SENDER_EMAIL
        msg['To'] = ", ".join(RECEIVER_EMAIL)
        msg['Subject'] = subject
        msg.attach(MIMEText(body, 'plain'))

        for attachment_path in attachments:
            if os.path.exists(attachment_path):
                filename = os.path.basename(attachment_path)
                with open(attachment_path, "rb") as attachment:
                    part = MIMEBase('application', 'octet-stream')
                    part.set_payload(attachment.read())
                    encoders.encode_base64(part)
                    part.add_header('Content-Disposition', f"attachment; filename={filename}")
                    msg.attach(part)

        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        server.login(SENDER_EMAIL, SENDER_PASSWORD)
        server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, msg.as_string())
        server.quit()
        print("ð§ Email sent successfully with all uploaders attached")
    except Exception as e:
        print(f"â Email sending error: {e}")

# ---------------- SAP FILE CREATOR ---------------- #
def generate_sap_upload():
    try:
        print("Starting SAP Uploader Generation...")
        period_df = pd.read_excel(PERIOD_FILE_PATH, header=None)
        period_val = str(period_df.iloc[0, 0]).strip()

        raw_df = pd.read_csv(RAW_DATA_FILE, usecols=['settled_at'], encoding='latin1', nrows=1)
        raw_date = pd.to_datetime(raw_df['settled_at'].iloc[0]).strftime('%d.%m.%Y')

        pay_df = pd.read_excel(INPUT_PAYMENT_SHEET)
        sap_entries = []
        mapping = [('91000467', 'net pg_payable', 'Escrow'), ('91000463', 'net_cod_payable', 'Cod')]

        for gl_code, col, txt_prefix in mapping:
            for _, row in pay_df.iterrows():
                val = pd.to_numeric(row[col], errors='coerce')
                if pd.notnull(val) and val > 0:
                    sap_entries.append({
                        'Customer': row['SAP'], 'Document_Date': raw_date, 'Posting_Date': raw_date,
                        'Company_Code': 'MKPL', 'Currency_Rate': 'INR', 'Reference': period_val,
                        'Doc_Header_Text': period_val, 'Assignment': 'MP payout', 'GL': gl_code,
                        'GST': '', 'Amount_GL': -abs(round(float(val), 2)), 'Amount_GST': '',
                        'Amount_Customer': abs(round(float(val), 2)), 'Profit_Center': '',
                        'Cost_Center': 'FINANCE', 'Text': f"MP payout {txt_prefix} {period_val}"
                    })

        wb = load_workbook(SAP_TEMPLATE_PATH)
        ws = wb.active
        for i, entry in enumerate(sap_entries):
            for c, val in enumerate(list(entry.values()), 1):
                ws.cell(row=2 + i, column=c).value = val
        wb.save(SAP_OUTPUT_FILE)
        
        generate_google_payment_uploader(pay_df, period_val, raw_date)
        generate_jv_uploaders(period_val, raw_date)

        send_gmail([SAP_OUTPUT_FILE, GOOGLE_UPLOADER_FILE, JV_GROSS_OUTPUT, JV_RETURN_OUTPUT])
    except Exception as e:
        print(f"â Critical Error: {e}")

# ---------------- GOOGLE PAYMENT FILE CREATOR ---------------- #
def generate_google_payment_uploader(pay_df, period_val, raw_date):
    try:
        google_sap_list = ["8302253", "8302697"]
        df_google = pay_df[pay_df["SAP"].astype(str).isin(google_sap_list)].copy()
        wb = load_workbook(SAP_TEMPLATE_PATH)
        ws = wb.active
        row_no = 2
        for _, row in df_google.iterrows():
            merchant_pay = round(float(pd.to_numeric(row["GMV"], errors="coerce") or 0), 2)
            data = [row["SAP"], raw_date, raw_date, "MKPL", "INR", period_val, period_val, 
                    "MP payout", "91000467", "", -merchant_pay, "", merchant_pay, "", "FINANCE", 
                    f"MP payout Escrow {period_val}"]
            for c, v in enumerate(data, 1):
                ws.cell(row=row_no, column=c).value = v
            row_no += 1
        wb.save(GOOGLE_UPLOADER_FILE)
    except Exception as e:
        print(f"â Error in Google Uploader: {e}")

# ---------------- JV UPLOADERS (GROSS & RETURN) ---------------- #
def generate_jv_uploaders(period_val, raw_date):
    try:
        print("Generating JV Gross and Return Uploaders...")
        jv_working = pd.read_excel(JV_WORKING_FILE)

        configs = [
            {
                'output': JV_GROSS_OUTPUT, 'sheet_to_keep': 'sales gross', 'sheet_to_remove': 'sales return',
                'col': 'direction_1', 'serial': 1, 'pk_main': '40', 'pk_sub': '11', 'acc_main': '13025016', 
                'text': 'MP Payt Gross', 'multiplier': 1
            },
            {
                'output': JV_RETURN_OUTPUT, 'sheet_to_keep': 'sales return', 'sheet_to_remove': 'sales gross',
                'col': 'direction_2', 'serial': 2, 'pk_main': '50', 'pk_sub': '01', 'acc_main': '13025014', 
                'text': 'MP Refunded Gross', 'multiplier': -1
            }
        ]

        for cfg in configs:
            wb = load_workbook(JV_FORMAT_FILE)
            
            # Remove the unwanted worksheet
            if cfg['sheet_to_remove'] in wb.sheetnames:
                del wb[cfg['sheet_to_remove']]
            
            ws = wb[cfg['sheet_to_keep']]
            
            # 1. Main Summary Row (Row 2)
            total_amt = round(jv_working[cfg['col']].sum() * cfg['multiplier'], 2)
            ws.cell(row=2, column=1).value = cfg['serial']
            ws.cell(row=2, column=2).value = raw_date
            ws.cell(row=2, column=3).value = "SA"
            ws.cell(row=2, column=4).value = "MKPL"
            ws.cell(row=2, column=5).value = raw_date
            ws.cell(row=2, column=6).value = "INR"
            ws.cell(row=2, column=7).value = period_val
            ws.cell(row=2, column=8).value = period_val
            ws.cell(row=2, column=9).value = cfg['pk_main']
            ws.cell(row=2, column=10).value = cfg['acc_main']
            ws.cell(row=2, column=13).value = total_amt
            
            # Static Fields & Assignment
            ws.cell(row=2, column=14).value = "v0"      # TaxCode
            ws.cell(row=2, column=15).value = "1000"    # BusinessPlace
            ws.cell(row=2, column=16).value = "1000"    # SectionCode
            ws.cell(row=2, column=17).value = "0001"    # PaymentTerm
            ws.cell(row=2, column=22).value = "Gross"   # Assignment
            ws.cell(row=2, column=23).value = "FINANCE" # CostCenter
            ws.cell(row=2, column=27).value = f"{cfg['text']} {period_val}"

            # 2. Merchant Rows (Row 3 Onwards)
            curr_row = 3
            for _, row in jv_working.iterrows():
                amt = round(float(row[cfg['col']]) * cfg['multiplier'], 2)
                if amt == 0: continue
                
                ws.cell(row=curr_row, column=1).value = cfg['serial']
                ws.cell(row=curr_row, column=9).value = cfg['pk_sub']
                ws.cell(row=curr_row, column=10).value = row["SAP"]
                ws.cell(row=curr_row, column=13).value = amt
                
                # Apply same static fields to merchant rows
                ws.cell(row=curr_row, column=14).value = "v0"
                ws.cell(row=curr_row, column=15).value = "1000"
                ws.cell(row=curr_row, column=16).value = "1000"
                ws.cell(row=curr_row, column=17).value = "0001"
                ws.cell(row=curr_row, column=22).value = "Gross"
                ws.cell(row=curr_row, column=23).value = "FINANCE"
                ws.cell(row=curr_row, column=27).value = f"{cfg['text']} {period_val}"
                curr_row += 1
            
            wb.save(cfg['output'])
        print("â JV Gross and Return uploaders saved. Return amounts are now negative.")
    except Exception as e:
        print(f"â JV Uploader Error: {e}")

if __name__ == "__main__":
    generate_sap_upload()